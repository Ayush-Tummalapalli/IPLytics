# ============================================================
# IPLytics — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Virtual Environment ---
venv/
env/
.venv/
.env/

# --- Environment Variables (secrets) ---
.env

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Data Files (too large for Git) ---
data/raw/*.csv
data/processed/*.csv
data/raw/*.json
data/processed/*.json

# --- Logs ---
*.log
logs/

# --- Streamlit ---
.streamlit/secrets.toml

# --- Misc ---
*.bak
*.tmp
.cache/
