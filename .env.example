# ============================================================
# IPLytics — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Database (PostgreSQL) ---
# Format: postgresql://username:password@host:port/database_name
# For local development, use your local PostgreSQL credentials.
# For production (Neon), use the connection string from your Neon dashboard.
DATABASE_URL=postgresql://postgres:password@localhost:5432/iplytics

# --- Google Gemini API ---
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Application Settings ---
APP_NAME=IPLytics
APP_VERSION=1.0.0
DEBUG=true

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Frontend ---
# The URL where the FastAPI backend is running
BACKEND_URL=http://localhost:8000
